window.onload = function() { renderStep1(); };

function renderStep1() {
  const container = document.getElementById("cat-list");
  container.innerHTML = "";
  CATEGORIES.forEach((cat, idx) => {
    if (state.openCats[idx] === undefined) state.openCats[idx] = true;
    const block = document.createElement("div");
    block.className = "category-block";
    const header = document.createElement("div");
    header.className = "cat-header";
    header.onclick = () => toggleCategory(idx);
    const left = document.createElement("div");
    left.className = "cat-header-left";
    const emoji = document.createElement("span");
    emoji.className = "cat-emoji"; emoji.textContent = cat.emoji;
    const name = document.createElement("span");
    name.className = "cat-name"; name.textContent = cat.name;
    const badge = document.createElement("span");
    badge.className = "cat-badge"; badge.id = `cat-badge-${idx}`;
    left.appendChild(emoji); left.appendChild(name); left.appendChild(badge);
    const chevron = document.createElement("span");
    chevron.className = `cat-chevron ${state.openCats[idx] ? "open" : ""}`;
    chevron.id = `cat-chev-${idx}`; chevron.textContent = "▼";
    header.appendChild(left); header.appendChild(chevron);
    block.appendChild(header);
    const tagsContainer = document.createElement("div");
    tagsContainer.className = "cat-tags";
    tagsContainer.id = `cat-tags-${idx}`;
    tagsContainer.style.display = state.openCats[idx] ? "flex" : "none";
    cat.tags.forEach(tagText => {
      const tagBtn = document.createElement("button");
      tagBtn.className = `tag ${state.selectedKws.has(tagText) ? "selected" : ""}`;
      tagBtn.textContent = tagText;
      tagBtn.onclick = () => toggleKw(tagText);
      tagsContainer.appendChild(tagBtn);
    });
    block.appendChild(tagsContainer);
    container.appendChild(block);
    updateCategoryBadge(idx);
  });
  updateSelectedBar();
}

function toggleCategory(idx) {
  state.openCats[idx] = !state.openCats[idx];
  const chev = document.getElementById(`cat-chev-${idx}`);
  const area = document.getElementById(`cat-tags-${idx}`);
  if (state.openCats[idx]) { chev.classList.add("open"); area.style.display = "flex"; }
  else { chev.classList.remove("open"); area.style.display = "none"; }
}

function toggleKw(kw) {
  if (state.selectedKws.has(kw)) {
    state.selectedKws.delete(kw);
  } else {
    state.selectedKws.add(kw);
  }
  
  // キーワードの追加/削除など構成の変更があった場合、以前の古い問いの選択状態をクリアする（バグ防止）
  state.chosenQKey = null;
  state.selectedFinalKws = new Set();
  
  renderStep1();
}

function updateCategoryBadge(idx) {
  const cat = CATEGORIES[idx];
  const badge = document.getElementById(`cat-badge-${idx}`);
  if (!badge) return;
  let count = 0;
  cat.tags.forEach(t => { if (state.selectedKws.has(t)) count++; });
  if (count > 0) { badge.textContent = count; badge.classList.add("visible"); }
  else { badge.classList.remove("visible"); }
}

function updateSelectedBar() {
  const countNum = document.getElementById("sidebar-count");
  const placeholder = document.getElementById("sidebar-placeholder");
  const tagsList = document.getElementById("sidebar-tags-list");
  const toStep2Btn = document.getElementById("to-step2-btn");
  
  const count = state.selectedKws.size;
  countNum.textContent = count;
  
  // プレースホルダー以外の古いミニタグ要素を完全にクリア
  const oldTags = tagsList.querySelectorAll(".mini-tag");
  oldTags.forEach(t => t.remove());

  if (count > 0) {
    toStep2Btn.disabled = false;
    if (placeholder) placeholder.style.display = "none";
    
    // かわいく統一された削除ボタン付きバッジ要素をサイドバーへ動的追加
    Array.from(state.selectedKws).forEach(t => {
      const minit = document.createElement("span");
      minit.className = "mini-tag";
      minit.innerHTML = `${t} <span class="remove-icon" title="削除">×</span>`;
      
      // サイドバーのミニタグ自体をタップしてサッと削除できるようにする親切設計
      minit.onclick = (e) => {
        e.stopPropagation();
        toggleKw(t);
      };
      
      tagsList.appendChild(minit);
    });
  } else {
    toStep2Btn.disabled = true;
    if (placeholder) placeholder.style.display = "block";
  }
}

function changeScreen(activeNum) {
  const appHeader = document.getElementById("app-header");
  if (appHeader) {
    appHeader.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  window.scrollTo(0, 0);
  document.documentElement.scrollTop = 0;
  document.body.scrollTop = 0;
  for (let i = 1; i <= 4; i++) {
    const scr = document.getElementById(`screen-${i}`);
    const tab = document.getElementById(`step-tab-${i}`);
    if (i === activeNum) { scr.classList.add("active"); tab.className = "step active"; }
    else { scr.classList.remove("active"); tab.className = i < activeNum ? "step done" : "step"; }
  }
}

function goBack(num) {
  if (num === 1) {
    state.chosenQKey = null;
    state.selectedFinalKws = new Set();
  }
  changeScreen(num);
}

function goToStep2() {
  changeScreen(2);
  const qScores = {};
  Q_KEYS.forEach(qKey => { qScores[qKey] = 0; });
  state.selectedKws.forEach(kw => {
    const scList = SCORES[kw];
    if (scList) Q_KEYS.forEach((qKey, i) => { qScores[qKey] += scList[i]; });
  });

  const sorted = Q_KEYS.map(qKey => ({ qKey, text: QUESTIONS[qKey], score: qScores[qKey] }))
    .sort((a, b) => b.score - a.score);

  // 0点フォールバック：アラート表示して戻る
  if (sorted[0].score === 0) {
    alert('キーワードが選ばれていないか、関連する問いが見つかりませんでした。\nもう少しキーワードを追加してみてください！');
    changeScreen(1);
    return;
  }

  const container = document.getElementById("results-list");
  container.innerHTML = "";
  const tieNoteArea = document.getElementById("tie-note-area");
  tieNoteArea.innerHTML = "";

  const maxScore = sorted[0].score;

  // タイ順位算出・3位以内を抽出
  let currentRank = 1, prevScore = null;
  const rankedSorted = sorted.map((item, idx) => {
    if (idx === 0) currentRank = 1;
    else if (item.score < prevScore) currentRank = idx + 1;
    prevScore = item.score;
    return { ...item, rank: currentRank };
  });

  const displayItems = rankedSorted.filter(item => item.rank <= 3);

  // 【差し戻しアラートの徹底スマート化】
  // 最大スコアが極めて低い（1点のみ）か、候補が6件以上に散らばりすぎて絞り込めない場合
  // 生徒に分かりやすい親切なアラートを出して自動でアコーディオン画面へ戻す
  if (maxScore <= 1 || displayItems.length >= 6) {
    alert('選んだキーワードが少なすぎるため、おすすめの問いを絞り込めませんでした。\nもう少し関連するキーワードをいくつか選んでみましょう！');
    changeScreen(1);
    return;
  }

  // もし前回の「選択中の問い（state.chosenQKey）」が再計算後の上位3つの表示候補に入っていない場合はリセットする
  if (state.chosenQKey) {
    const isValid = displayItems.some(item => item.qKey === state.chosenQKey);
    if (!isValid) {
      state.chosenQKey = null;
    }
  }

  // 絞り込みが成功（候補が2〜5件）している場合の綺麗に整ったメッセージ表示
  if (displayItems.length > 3) {
    const tieNote = document.createElement("div");
    tieNote.className = "tie-note";
    tieNote.innerHTML = `💡 <strong>おすすめ候補が同じマッチ度で並んでいます（候補：${displayItems.length}つ）。</strong>関心がある問いを1つ選んでください。`;
    tieNoteArea.appendChild(tieNote);
  }

  displayItems.forEach(item => {
    const card = document.createElement("div");
    card.className = `question-card${state.chosenQKey === item.qKey ? " selected-q" : ""}`;
    card.onclick = () => selectQuestion(item.qKey);

    const qHeader = document.createElement("div");
    qHeader.className = "q-header";
    const rankSpan = document.createElement("span");
    rankSpan.className = `q-rank rank-${Math.min(item.rank, 3) === item.rank ? item.rank : 'n'}`;
    rankSpan.textContent = item.rank === 1 ? "🥇" : item.rank === 2 ? "🥈" : item.rank === 3 ? "🥉" : item.rank;

    const labelSpan = document.createElement("span");
    labelSpan.className = "q-label"; labelSpan.textContent = item.qKey;
    const scoreSpan = document.createElement("span");
    scoreSpan.className = "q-score"; scoreSpan.textContent = `マッチ度: ${item.score}点`;

    qHeader.appendChild(rankSpan); qHeader.appendChild(labelSpan); qHeader.appendChild(scoreSpan);

    const textDiv = document.createElement("div");
    textDiv.className = "q-text"; textDiv.textContent = item.text;

    const selectBtn = document.createElement("button");
    selectBtn.className = "q-select-btn";
    selectBtn.textContent = state.chosenQKey === item.qKey ? "✓ 選択中" : "この問いを選ぶ";

    card.appendChild(qHeader); card.appendChild(textDiv); card.appendChild(selectBtn);
    container.appendChild(card);
  });

  document.getElementById("to-step3-btn").disabled = !state.chosenQKey;
}

function selectQuestion(qKey) {
  state.chosenQKey = qKey;
  goToStep2();
}

function goToStep3() {
  changeScreen(3);
  const display = document.getElementById("chosen-q-display");
  display.innerHTML = `
    <div class="q-label-white">選択した問い (${state.chosenQKey})</div>
    <div class="q-text-white">${QUESTIONS[state.chosenQKey]}</div>
  `;

  const qIndex = Q_KEYS.indexOf(state.chosenQKey);
  const relKwsSet = new Set();

  // Step1で選んだキーワードのうちこの問いに関連するものを優先
  state.selectedKws.forEach(kw => {
    if (SCORES[kw] && SCORES[kw][qIndex] > 0) relKwsSet.add(kw);
  });
  // スコアDB全体からもマージ
  Object.keys(SCORES).forEach(kw => {
    if (SCORES[kw][qIndex] > 0) relKwsSet.add(kw);
  });

  currentRelKws = Array.from(relKwsSet);

  // 問いが変わった場合、関係ないキーワードはリセット
  state.selectedFinalKws.forEach(kw => {
    if (!relKwsSet.has(kw)) state.selectedFinalKws.delete(kw);
  });

  renderFinalKwTags();
}

function renderFinalKwTags() {
  const container = document.getElementById("kw-tags-area");
  container.innerHTML = "";
  const isMaxReached = state.selectedFinalKws.size >= 5;

  currentRelKws.forEach(kw => {
    const btn = document.createElement("button");
    btn.className = "kw-tag";
    const isSelected = state.selectedFinalKws.has(kw);
    if (isSelected) btn.classList.add("kw-selected");
    if (isMaxReached && !isSelected) { btn.disabled = true; btn.classList.add("kw-disabled"); }
    btn.textContent = kw;
    btn.onclick = () => toggleFinalKw(kw);
    container.appendChild(btn);
  });

  const size = state.selectedFinalKws.size;
  document.getElementById("kw-count-num").textContent = `${size} / 5`;
  document.getElementById("to-step4-btn").disabled = (size < 3 || size > 5);
}

function toggleFinalKw(kw) {
  if (state.selectedFinalKws.has(kw)) state.selectedFinalKws.delete(kw);
  else if (state.selectedFinalKws.size < 5) state.selectedFinalKws.add(kw);
  renderFinalKwTags();
}

function goToStep4() {
  changeScreen(4);
  const container = document.getElementById("confirm-box");
  container.innerHTML = "";

  const rowQ = document.createElement("div");
  rowQ.className = "confirm-row";
  rowQ.innerHTML = `<div class="confirm-label">探究する問いの番号</div>
    <div class="confirm-value" style="font-weight:700;color:var(--ocean);">${state.chosenQKey}</div>`;
  container.appendChild(rowQ);

  const rowQText = document.createElement("div");
  rowQText.className = "confirm-row";
  rowQText.innerHTML = `<div class="confirm-label">探究する問いの内容</div>
    <div class="confirm-value">${QUESTIONS[state.chosenQKey]}</div>`;
  container.appendChild(rowQText);

  const rowTags = document.createElement("div");
  rowTags.className = "confirm-row";
  const tagLabel = document.createElement("div");
  tagLabel.className = "confirm-label"; tagLabel.textContent = "深堀りキーワード（3〜5個）";
  rowTags.appendChild(tagLabel);
  const tagsWrapper = document.createElement("div");
  tagsWrapper.className = "confirm-tags";
  Array.from(state.selectedFinalKws).forEach(kw => {
    const tSpan = document.createElement("span");
    tSpan.className = "confirm-tag"; tSpan.textContent = kw;
    tagsWrapper.appendChild(tSpan);
  });
  rowTags.appendChild(tagsWrapper);
  container.appendChild(rowTags);
}
</script>
</body>
</html>
